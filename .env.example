# Environment Configuration for Alumni Feedback System

# Flask Configuration
FLASK_ENV=production
DEBUG=False
SECRET_KEY=your-secret-key-change-this-in-production

# Database Configuration
DATABASE_PATH=database/dashboard.db

# CORS Configuration
CORS_ORIGINS=*

# Webhook Configuration
WEBHOOK_SECRET=your-webhook-secret-key

# Form Configuration
FORM_PASSWORD=your-form-password-here

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Server Configuration
PORT=7860
HOST=0.0.0.0

# Google Apps Script Configuration (for webhook callbacks)
GOOGLE_FORM_ID=your-google-form-id
GOOGLE_APPS_SCRIPT_WEBHOOK_URL=https://your-hf-space.hf.space/api/v1/webhook/forms/submit

# Google Calendar (optional, for alumni speaker events)
GOOGLE_CALENDAR_ID=your-calendar-id

# Data Quality Settings
DATA_QUALITY_THRESHOLD=80
MIN_WORD_LENGTH=3
MAX_KEYWORDS=10

# Performance Settings
SESSION_TIMEOUT=3600
CACHE_TIMEOUT=300

# Hugging Face Configuration
HF_TOKEN=your-huggingface-token-here
HF_SPACE_ID=vrfefavr/Feedback_DashBoard
HF_REPO_TYPE=space
